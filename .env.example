# =============================================================================
# SmartCampus SaaS — Configuration d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs réelles
# NE JAMAIS committer le fichier .env sur Git
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_NAME="SmartCampus"
APP_ENV=local                        # local | production
APP_DEBUG=true                       # false en production
APP_URL=http://localhost/smartcampus_php/public
APP_SECRET=changez_cette_valeur_par_une_chaine_aleatoire_de_64_chars

# -----------------------------------------------------------------------------
# BASE DE DONNÉES
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=smartcampus
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# -----------------------------------------------------------------------------
# API GROQ (Assistant IA)
# Obtenez votre clé sur https://console.groq.com
# -----------------------------------------------------------------------------
GROQ_API_KEY=votre_cle_groq_ici
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# SESSIONS
# -----------------------------------------------------------------------------
SESSION_LIFETIME=7200               # Durée en secondes (2h)
SESSION_NAME=smartcampus_session

# -----------------------------------------------------------------------------
# SÉCURITÉ — Rate Limiting (tentatives de connexion)
# -----------------------------------------------------------------------------
LOGIN_MAX_ATTEMPTS=5                # Tentatives max avant blocage
LOGIN_LOCKOUT_TIME=900              # Blocage en secondes (15 min)

# -----------------------------------------------------------------------------
# UPLOADS
# -----------------------------------------------------------------------------
UPLOAD_MAX_SIZE=2097152             # Taille max en octets (2 Mo)
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,webp

# -----------------------------------------------------------------------------
# SUPER ADMIN (compte maître de la plateforme)
# À changer impérativement avant la mise en production
# -----------------------------------------------------------------------------
SUPER_ADMIN_EMAIL=superadmin@smartcampus.com
SUPER_ADMIN_PASSWORD=SuperAdmin@2025!

# -----------------------------------------------------------------------------
# PAGINATION
# -----------------------------------------------------------------------------
ITEMS_PER_PAGE=15

# -----------------------------------------------------------------------------
# EMAIL (optionnel — pour reset de mot de passe)
# -----------------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@smartcampus.com
MAIL_FROM_NAME="SmartCampus"
